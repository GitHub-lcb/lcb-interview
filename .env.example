MYSQL_ROOT_PASSWORD=change-root-password
DB_USERNAME=lcb
DB_PASSWORD=change-app-password
ADMIN_TOKEN=change-admin-token

# 小内存服务器建议先关闭远程 AI 评分；需要时填入真实密钥并改为 true。
AI_INTERVIEW_ENABLED=false
AI_OPENCODE_API_KEY=
AI_DEEPSEEK_MODEL=deepseek-v4-pro
AI_DEEPSEEK_URL=https://opencode.ai/zen/go/v1/chat/completions
AI_INTERVIEW_TIMEOUT_MS=8000

# 2G 内存服务器建议保守配置；4G 以上可按需调大。
JAVA_OPTS=-Xms256m -Xmx768m -XX:+ExitOnOutOfMemoryError
REDIS_MAXMEMORY=128mb
